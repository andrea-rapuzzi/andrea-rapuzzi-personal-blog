---
import { Image } from "astro:assets";
import imgSpeaker from "../assets/photos/polaroid/Speaker_al_CX_Circle.jpg";
import imgOlimpiadi from "../assets/photos/polaroid/Olmpiadi_2026.jpeg";
import imgFriends from "../assets/photos/polaroid/Goodbye_Friends.jpg";
import imgAngera from "../assets/photos/polaroid/Traversata_di_Angera.jpeg";
import imgMarried from "../assets/photos/polaroid/Just_Married.jpg";
import imgGiappone from "../assets/photos/polaroid/Viaggio_in_giappone.jpg";

type PhotoReal = {
  src: ImageMetadata;
  alt: string;
  caption: string;
  rotate: number;
};

type PhotoPlaceholder = {
  src?: undefined;
  alt: string;
  caption: string;
  rotate: number;
  bg: string;
  width: number;
  height: number;
};

type Photo = PhotoReal | PhotoPlaceholder;

const photos: Photo[] = [
  {
    src: imgOlimpiadi,
    alt: "Hockey alle Olimpiadi 2026",
    caption: "Olimpiadi '26",
    rotate: -1.2,
  },
  {
    src: imgFriends,
    alt: "Con gli amici",
    caption: "Goodbye Friends",
    rotate: 2.5,
  },
  {
    src: imgAngera,
    alt: "Traversata di Angera",
    caption: "Angera",
    rotate: -0.8,
  },
  {
    src: imgSpeaker,
    alt: "On stage al CX Circle",
    caption: "CX Circle",
    rotate: -2.0,
  },
  {
    src: imgGiappone,
    alt: "Viaggio in Giappone",
    caption: "Giappone",
    rotate: 1.5,
  },
  {
    src: imgMarried,
    alt: "Appena sposati",
    caption: "Just Married",
    rotate: 1.8,
  },
];
---

<section class="polaroids">
  <div class="polaroids__header">
    <h2 class="polaroids__heading">Momenti</h2>
    <p class="polaroids__sub">Una raccolta non curata</p>
  </div>

  <div
    class="polaroids__track-wrap"
    role="region"
    aria-label="Galleria fotografica polaroid"
  >
    <div class="polaroids__track">
      {
        photos.map((photo) => (
          <div
            class="polaroid"
            style={
              photo.src
                ? `--rotate: ${photo.rotate}deg;`
                : `--rotate: ${photo.rotate}deg; --w: ${photo.width}px; --h: ${photo.height}px;`
            }
          >
            {photo.src ? (
              <Image
                src={photo.src}
                alt={photo.alt}
                width={400}
                height={440}
                class="polaroid__photo polaroid__photo--real"
              />
            ) : (
              <div
                class="polaroid__photo"
                style={`background: ${photo.bg};`}
                aria-label={photo.alt}
              />
            )}
            <p class="polaroid__caption">{photo.caption}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .polaroids {
    padding: 0 0 var(--section-gap);
    overflow: hidden;
  }

  .polaroids__header {
    padding: 0 2rem;
    max-width: var(--max-width);
    margin: 0 auto 1.25rem;
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .polaroids__heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .polaroids__sub {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .polaroids__track-wrap {
    overflow-x: auto;
    overflow-y: visible;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2rem;
  }

  .polaroids__track-wrap::-webkit-scrollbar {
    display: none;
  }

  .polaroids__track-wrap:active {
    cursor: grabbing;
  }

  .polaroids__track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 2rem 2rem 1rem max(2rem, calc((100vw - var(--max-width)) / 2));
    width: max-content;
  }

  .polaroid {
    flex-shrink: 0;
    width: var(--w, 200px);
    background: #ffffff;
    padding: 10px;
    display: flex;
    flex-direction: column;
    box-shadow:
      0 4px 18px rgba(0, 0, 0, 0.13),
      0 1px 4px rgba(0, 0, 0, 0.06);
    transform: rotate(var(--rotate));
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    will-change: transform;
  }

  .polaroid:hover {
    transform: rotate(0deg) scale(1.04);
    box-shadow:
      0 12px 36px rgba(0, 0, 0, 0.18),
      0 2px 8px rgba(0, 0, 0, 0.08);
    z-index: 10;
    position: relative;
  }

  .polaroid__photo {
    width: 100%;
    height: var(--h);
    display: block;
  }

  .polaroid__photo--real {
    width: 200px;
    height: 220px;
    object-fit: cover;
  }

  .polaroid__caption {
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Caveat", "Comic Sans MS", cursive, sans-serif;
    font-size: 1rem;
    color: #444;
    text-align: center;
    line-height: 1.2;
    padding: 0 4px;
  }
</style>

<script>
  // Drag-to-scroll on polaroid carousel
  const track = document.querySelector(
    ".polaroids__track-wrap",
  ) as HTMLElement | null;
  if (track) {
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;

    track.addEventListener("mousedown", (e) => {
      isDown = true;
      track.style.cursor = "grabbing";
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    track.addEventListener("mouseleave", () => {
      isDown = false;
      track.style.cursor = "grab";
    });
    track.addEventListener("mouseup", () => {
      isDown = false;
      track.style.cursor = "grab";
    });

    track.addEventListener("mousemove", (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });
  }
</script>
