---

<section class="polaroids">
  <div class="polaroids__header">
    <h2 class="polaroids__heading">Momenti</h2>
    <p class="polaroids__sub">Una raccolta non curata</p>
  </div>

  <div class="polaroids__track-wrap" role="region" aria-label="Galleria fotografica polaroid">
    <div class="polaroids__track">
      {photos.map((photo) => (
        <div
          class="polaroid"
          style={`--rotate: ${photo.rotate}deg; --w: ${photo.width}px; --h: ${photo.height}px;`}
        >
          <div class="polaroid__photo" style={`background: ${photo.bg};`} aria-label={photo.alt}></div>
          <p class="polaroid__caption">{photo.caption}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .polaroids {
    padding: 0 0 var(--section-gap);
    overflow: hidden;
  }

  .polaroids__header {
    padding: 0 2rem;
    max-width: var(--max-width);
    margin: 0 auto 2.5rem;
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .polaroids__heading {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
  }

  .polaroids__sub {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .polaroids__track-wrap {
    overflow-x: auto;
    overflow-y: visible;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2rem;
  }

  .polaroids__track-wrap::-webkit-scrollbar {
    display: none;
  }

  .polaroids__track-wrap:active {
    cursor: grabbing;
  }

  .polaroids__track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 2rem 2rem 1rem max(2rem, calc((100vw - var(--max-width)) / 2));
    width: max-content;
  }

  .polaroid {
    flex-shrink: 0;
    width: var(--w);
    background: #ffffff;
    padding: 10px 10px 40px;
    box-shadow: 0 4px 18px rgba(0,0,0,0.13), 0 1px 4px rgba(0,0,0,0.06);
    transform: rotate(var(--rotate));
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    will-change: transform;
  }

  .polaroid:hover {
    transform: rotate(0deg) scale(1.04);
    box-shadow: 0 12px 36px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.08);
    z-index: 10;
    position: relative;
  }

  .polaroid__photo {
    width: 100%;
    height: var(--h);
    display: block;
  }

  .polaroid__caption {
    margin-top: 8px;
    font-family: 'Caveat', 'Comic Sans MS', cursive, sans-serif;
    font-size: 0.875rem;
    color: #444;
    text-align: center;
    line-height: 1;
    padding: 0 4px;
  }
</style>

<script>
  // Drag-to-scroll on polaroid carousel
  const track = document.querySelector('.polaroids__track-wrap') as HTMLElement | null;
  if (track) {
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.style.cursor = 'grabbing';
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    track.addEventListener('mouseleave', () => { isDown = false; track.style.cursor = 'grab'; });
    track.addEventListener('mouseup', () => { isDown = false; track.style.cursor = 'grab'; });

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });
  }
</script>
