---
interface Props {
  heading?: string;
  subtitle?: string;
  bio?: string;
  cta?: { label: string; href: string } | null;
  topPadding?: string;
}

const {
  heading = "Andrea Rapuzzi",
  subtitle = "CX Lead @Nestlé Waters",
  bio = "Ciao! io sono Andrea e questo è il mio piccolo angolo di internet. Digital marketer per passione, programmatore della domenica, pessimo copywriter. Dal lunedì al venerdì mi occupo di CX in Nestlé, mentre nel weekend perdo tempo tra film, progetti sgangherati, e qualche buon vinile.",
  cta = {
    label: "Il mio CV",
    href: "https://www.linkedin.com/in/andrea-rapuzzi/",
  },
  topPadding = "7rem",
} = Astro.props;
---

<section class="hero" style={`padding-top: ${topPadding}`}>
  <div class="hero__inner">
    <h1 class="hero__name">{heading}</h1>
    {subtitle && <p class="hero__title">{subtitle}</p>}
    {bio && <p class="hero__bio">{bio}</p>}
    {
      cta && (
        <div class="hero__links">
          <a href={cta.href} class="hero__link hero__link--primary">
            {cta.label}
          </a>
        </div>
      )
    }
  </div>
  <div class="hero__deco" aria-hidden="true">
    <span class="hero__deco-year">2026</span>
  </div>
</section>

<style>
  .hero {
    padding: 7rem 2rem 5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 2rem;
  }

  .hero__meta {
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero__label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.65rem;
    border-radius: 99px;
  }

  .hero__name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0em;
    color: var(--color-heading);
  }

  .hero__title {
    font-family: var(--font-sans);
    font-style: normal;
    font-size: clamp(0.75rem, 1.4vw, 1rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-top: 0.25rem;
  }

  .hero__bio {
    max-width: 52ch;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-muted);
    margin-top: 1.75rem;
  }

  .hero__links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .hero__link {
    font-size: 0.9375rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .hero__link--primary {
    background: var(--color-ink);
    color: #fff;
    padding: 0.625rem 1.375rem;
    border-radius: 4px;
  }

  .hero__link--primary:hover {
    opacity: 0.8;
  }

  .hero__link:not(.hero__link--primary):hover {
    opacity: 0.6;
  }

  .hero__deco {
    display: flex;
    align-items: end;
    padding-bottom: 0.5rem;
  }

  .hero__deco-year {
    writing-mode: vertical-rl;
    font-size: 0.6875rem;
    font-weight: 300;
    letter-spacing: 0.2em;
    color: var(--color-border);
    user-select: none;
  }

  @media (max-width: 640px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 5rem;
    }

    .hero__deco {
      display: none;
    }
  }
</style>
