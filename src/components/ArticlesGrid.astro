---
import { getCollection } from 'astro:content';
import { tagColor } from '../utils/tagColors';

const allPosts = await getCollection('posts');

const articles = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6)
  .map((post) => {
    const formattedDate = post.data.pubDate.toLocaleDateString('it-IT', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
    });
    return {
      title: post.data.title,
      excerpt: post.data.description,
      date: formattedDate,
      tags: post.data.tags,
      url: `/posts/${post.slug}`,
    };
  });
---

<section class="articles">
  <div class="articles__inner">
    <header class="articles__header">
      <h2 class="articles__heading">Scrittura</h2>
      <a href="/blog" class="articles__all">Tutto →</a>
    </header>

    <div class="articles__grid">
      {articles.map((item) => (
        <a href={item.url} class="article-card">
          <div class="article-card__tags">
            {item.tags.map((tag: string) => {
              const { bg, text } = tagColor(tag);
              return <span class="article-card__tag" style={`background:${bg};color:${text}`}>{tag}</span>;
            })}
          </div>
          <h3 class="article-card__title">{item.title}</h3>
          <p class="article-card__excerpt">{item.excerpt}</p>
          <footer class="article-card__footer">
            <time class="article-card__date" datetime={item.date}>{item.date}</time>
          </footer>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .articles {
    padding: 0 2rem var(--section-gap);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .articles__inner {
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
  }

  .articles__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .articles__heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
  }

  .articles__all {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    transition: opacity 0.2s;
  }

  .articles__all:hover {
    opacity: 0.7;
  }

  .articles__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .article-card {
    background: #FFFFFF;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
  }

  .article-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .article-card__tag {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
  }

  .article-card__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-heading);
  }

  .article-card__excerpt {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-muted);
    flex: 1;
  }

  .article-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--color-border);
    padding-top: 0.875rem;
    margin-top: auto;
  }

  .article-card__date {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .articles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .articles__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
