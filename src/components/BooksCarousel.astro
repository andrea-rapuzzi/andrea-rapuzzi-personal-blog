---
const books = [
  {
    title: "Le mie stupide intenzioni",
    author: "Bernardo Zannoni",
    year: "2021",
    note: "Una faina che impara a leggere e scopre che la vita fa male comunque.",
    spine: "#8a5a3a",
    cover: "linear-gradient(160deg, #c49070 0%, #8a5a3a 100%)",
  },
  {
    title: "Quello che possiamo sapere",
    author: "Ian McEwan",
    year: "2023",
    note: "La coscienza, il libero arbitrio e una storia d'amore improbabile.",
    spine: "#3a5a7a",
    cover: "linear-gradient(160deg, #6a9aba 0%, #3a5a7a 100%)",
  },
  {
    title: "Fiori per Algernon",
    author: "Daniel Keyes",
    year: "1966",
    note: "L'intelligenza non è sinonimo di felicità. Charlie lo impara nel modo peggiore.",
    spine: "#6a3a6a",
    cover: "linear-gradient(160deg, #aa6aaa 0%, #6a3a6a 100%)",
  },
  {
    title: "Project Hail Mary",
    author: "Andy Weir",
    year: "2021",
    note: "Un uomo solo nello spazio, senza memoria. Il miglior sci-fi degli ultimi anni.",
    spine: "#2a5a4a",
    cover: "linear-gradient(160deg, #5a9a80 0%, #2a5a4a 100%)",
  },
  {
    title: "Schegge",
    author: "Bret Easton Ellis",
    year: "2023",
    note: "Los Angeles, gli anni Ottanta, il terrore che striscia sotto la superficie.",
    spine: "#4a4a4a",
    cover: "linear-gradient(160deg, #8a8a8a 0%, #4a4a4a 100%)",
  },
  {
    title: "Considera l'aragosta",
    author: "David Foster Wallace",
    year: "2005",
    note: "Saggi che cambiano prospettiva. Ogni pagina è un esercizio di attenzione.",
    spine: "#7a5a2a",
    cover: "linear-gradient(160deg, #baa060 0%, #7a5a2a 100%)",
  },
  {
    title: "Abbiamo smesso di capire il mondo",
    author: "Benjamín Labatut",
    year: "2020",
    note: "La scienza al limite della comprensione umana. Bellissimo e inquietante.",
    spine: "#2a3a5a",
    cover: "linear-gradient(160deg, #5a6a9a 0%, #2a3a5a 100%)",
  },
];
---

<section class="books">
  <div class="books__header">
    <h2 class="books__heading">Letture</h2>
  </div>

  <div class="books__track-wrap" role="region" aria-label="Libri letti di recente">
    <div class="books__track">
      {books.map((book) => (
        <div class="book-card">
          <div class="book-card__cover" style={`background: ${book.cover};`}>
            <div class="book-card__spine" style={`background: ${book.spine};`}></div>
            <div class="book-card__cover-inner">
              <p class="book-card__cover-title">{book.title}</p>
              <p class="book-card__cover-author">{book.author}</p>
            </div>
          </div>
          <div class="book-card__info">
            <h3 class="book-card__title">{book.title}</h3>
            <p class="book-card__author">{book.author} · {book.year}</p>
            <p class="book-card__note">"{book.note}"</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .books {
    padding: 0 0 var(--section-gap);
    overflow: hidden;
  }

  .books__header {
    padding: 3rem 2rem 2.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .books__heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .books__all {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    transition: opacity 0.2s;
  }

  .books__all:hover {
    opacity: 0.7;
  }

  .books__track-wrap {
    overflow-x: auto;
    overflow-y: hidden;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .books__track-wrap::-webkit-scrollbar {
    display: none;
  }

  .books__track-wrap:active {
    cursor: grabbing;
  }

  .books__track {
    display: flex;
    gap: 1.5rem;
    padding: 0.5rem 2rem 2rem max(2rem, calc((100vw - var(--max-width)) / 2));
    width: max-content;
    align-items: flex-start;
  }

  .book-card {
    flex-shrink: 0;
    width: 168px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .book-card__cover {
    width: 168px;
    height: 224px;
    border-radius: 2px 6px 6px 2px;
    position: relative;
    box-shadow:
      -4px 0 8px rgba(0,0,0,0.25),
      4px 4px 16px rgba(0,0,0,0.18),
      inset 2px 0 4px rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .book-card:hover .book-card__cover {
    transform: translateY(-5px) rotate(-1deg);
    box-shadow:
      -4px 0 10px rgba(0,0,0,0.3),
      8px 10px 24px rgba(0,0,0,0.22),
      inset 2px 0 4px rgba(255,255,255,0.1);
  }

  .book-card__spine {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 18px;
    border-radius: 2px 0 0 2px;
    opacity: 0.85;
  }

  .book-card__cover-inner {
    padding: 1rem 1rem 1rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    width: 100%;
  }

  .book-card__cover-title {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    font-weight: 700;
    color: rgba(255,255,255,0.95);
    line-height: 1.3;
    text-shadow: 0 1px 3px rgba(0,0,0,0.3);
  }

  .book-card__cover-author {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.75);
    margin-top: 0.25rem;
    text-shadow: 0 1px 2px rgba(0,0,0,0.25);
  }

  .book-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .book-card__title {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-ink);
  }

  .book-card__author {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .book-card__note {
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--color-muted);
    font-style: italic;
    margin-top: 0.25rem;
  }
</style>

<script>
  // Drag-to-scroll on books carousel
  const track = document.querySelector('.books__track-wrap') as HTMLElement | null;
  if (track) {
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.style.cursor = 'grabbing';
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    track.addEventListener('mouseleave', () => { isDown = false; track.style.cursor = 'grab'; });
    track.addEventListener('mouseup', () => { isDown = false; track.style.cursor = 'grab'; });

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });
  }
</script>
