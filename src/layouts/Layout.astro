---
interface Props {
  title?: string;
}
const { title = "Andrea Rapuzzi — CX Lead" } = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Pirata+One&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="preload" href="/Bajern.otf" as="font" type="font/otf" crossorigin="anonymous" />
    <script is:inline>
      document.fonts.load('1em Bajern').then(function() {
        document.documentElement.classList.add('fonts-ready');
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Bajern';
    src: url('/Bajern.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: block;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #F7FBFC;
    --color-surface: #ffffff;
    --color-ink: #1a1a18;
    --color-heading: #30323E;
    --color-muted: #6b6b65;
    --color-accent: #74A89E;
    --color-border: #d8e0e4;
    --font-display: Georgia, serif;
    --font-serif: 'Playfair Display', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
    --max-width: 1200px;
    --section-gap: 5rem;
  }

  html {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-ink);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1, h2, h3, h4, h5, h6 {
    color: var(--color-heading);
  }

  html.fonts-ready {
    --font-display: 'Bajern', Georgia, serif;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  a {
    color: inherit;
    text-decoration: none;
  }
</style>
