---
import { tagColor } from '../utils/tagColors';

const { frontmatter } = Astro.props;

const date = new Date(frontmatter.pubDate);
const formattedDate = date.toLocaleDateString('it-IT', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{frontmatter.title} — Andrea Rapuzzi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="preload" href="/Bajern.otf" as="font" type="font/otf" crossorigin="anonymous" />
    <script is:inline>
      document.fonts.load('1em Bajern').then(function() {
        document.documentElement.classList.add('fonts-ready');
      });
    </script>
  </head>
  <body>
    <div class="post-page">
      <header class="post-header">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol class="breadcrumb__list">
            <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Home</a></li>
            <li class="breadcrumb__item"><a href="/blog" class="breadcrumb__link">Scrittura</a></li>
            <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{frontmatter.title}</li>
          </ol>
        </nav>

        <h1 class="post-title">{frontmatter.title}</h1>
        {frontmatter.description && (
          <p class="post-description">{frontmatter.description}</p>
        )}

        <div class="post-meta">
          {frontmatter.tags?.map((tag: string) => {
            const { bg, text } = tagColor(tag);
            return <span class="post-meta__tag" style={`background:${bg};color:${text}`}>{tag}</span>;
          })}
          <time class="post-meta__date">{formattedDate}</time>
        </div>
      </header>

      <article class="post-body">
        <slot />
      </article>

      <footer class="post-footer">
        <a href="/blog" class="post-footer__back">← Tutti gli articoli</a>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Bajern';
    src: url('/Bajern.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: block;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #F7FBFC;
    --color-surface: #ffffff;
    --color-ink: #1a1a18;
    --color-heading: #30323E;
    --color-muted: #6b6b65;
    --color-accent: #74A89E;
    --color-border: #d8e0e4;
    --font-display: Georgia, serif;
    --font-serif: 'Playfair Display', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  html.fonts-ready {
    --font-display: 'Bajern', Georgia, serif;
  }

  html {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-ink);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  body { min-height: 100vh; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  .breadcrumb__list { list-style: none; }
</style>

<style>
  /* ── Outer container — allineato al hero ── */
  .post-page {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  /* ── Text column — larghezza leggibile, left-aligned ── */
  .post-header,
  .post-body,
  .post-footer {
    max-width: 68ch;
  }

  /* ── Breadcrumb ── */
  .post-header {
    padding-top: 3.5rem;
    padding-bottom: 5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .breadcrumb {
    margin-bottom: 2.5rem;
  }

  .breadcrumb__list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .breadcrumb__item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .breadcrumb__item + .breadcrumb__item::before {
    content: '/';
    color: var(--color-border);
  }

  .breadcrumb__link {
    color: var(--color-muted);
    transition: color 0.2s;
  }

  .breadcrumb__link:hover {
    color: var(--color-ink);
  }

  .breadcrumb__item--current {
    color: var(--color-ink);
    font-weight: 500;
    /* truncate if too long */
    max-width: 40ch;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Post meta ── */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .post-meta__tag {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }

  .post-meta__date {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-left: 0.25rem;
  }

  /* ── Post title ── */
  .post-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0em;
    color: var(--color-heading);
    margin-top: 7rem;
    margin-bottom: 0.25rem;
  }

  .post-description {
    max-width: 52ch;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-muted);
    margin-top: 0.5rem;
  }

  /* ── Post body ── */
  .post-body {
    padding-top: 3rem;
    padding-bottom: 3rem;
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-ink);
  }

  .post-body :global(h2) {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-heading);
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .post-body :global(h3) {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-heading);
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .post-body :global(p) {
    margin-bottom: 1.625rem;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.625rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 2.5rem 0;
    color: var(--color-muted);
    font-style: italic;
    font-size: 1.125rem;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .post-body :global(code) {
    font-size: 0.875em;
    background: #f0ece4;
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  .post-body :global(pre) {
    background: var(--color-ink);
    color: #f8f6f1;
    padding: 1.5rem;
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 1.625rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-body :global(img) {
    border-radius: 6px;
    margin: 2rem 0;
  }

  /* ── Footer ── */
  .post-footer {
    padding-top: 2rem;
    padding-bottom: 5rem;
    border-top: 1px solid var(--color-border);
  }

  .post-footer__back {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    transition: color 0.2s;
  }

  .post-footer__back:hover {
    color: var(--color-ink);
  }

  @media (max-width: 640px) {
    .breadcrumb__item--current {
      max-width: 24ch;
    }
  }
</style>
